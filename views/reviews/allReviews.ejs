<%- include ("../partials/header.ejs") %>

<h2>All Reviews</h2>

<a href="/review/addReview" class="view-btn">Create</a>


<% reviews.forEach(review => { %>


<div class="container">
    <a href="/review/<%=review._id%>"><div class="review-card"> <%= review.title %>, by <%= review.reviewer.username %>
    </div></a>
</div>


<% }) %>


<%- include ("../partials/footer.ejs") %>
