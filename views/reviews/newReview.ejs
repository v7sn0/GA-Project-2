<%- include ("../partials/header.ejs") %>

<h2>Create New Review</h2>

<form action="/review" method="post">
  <input type="text" name="title" placeholder="Title" required />
  <textarea name="paragraph" placeholder="Description" required></textarea>
  <input type="number" name="rating" placeholder="Rating" required />
  <input type="hidden" name="reviewer" value="<%= user._id %>" required />
  <!-- <input type="text" name="phone" placeholder="Phone" /> -->
  <select name="phone">
    <!-- <option value="">2</option> -->
    <% phones.forEach(phone => { %>
      <option value="<%= phone._id %>"><%= phone.name %></option>
  <%  }) %>
  </select>
  <button type="submit">Create</button>
</form>
<%- include ("../partials/footer.ejs")%>
